# Ignore everything, allow all directories (so git traverses them)
*
!*/

# Top-level
!.gitignore

# Zsh
!.config/zsh/.zshrc
!.config/zsh/.zprofile
!.config/zsh/.zsh_plugins.txt

# Git
!.config/git/config
!.config/git/ignore

# Ghostty
!.config/ghostty/config

# Neovim
!.config/nvim/init.lua
!.config/nvim/lua/**

# Karabiner
!.config/karabiner/karabiner.json

# Tmux
!.config/tmux/tmux.conf

# Vim
!.config/vim/vimrc

# Btop
!.config/btop/btop.conf

# Misc
!.config/Brewfile
!.config/README.md
